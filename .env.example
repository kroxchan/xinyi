# =============================================================================
# xinyi 环境变量配置
# 复制此文件为 .env 即可（.env 在 .gitignore 中，不会被提交）
# =============================================================================

# ── API 配置 ──────────────────────────────────────────────────────────────

# OpenAI 兼容 API Key（必填）
WECHAT_TWIN_API_KEY=sk-your-key-here

# API 模型（可选）：仅当 config.yaml 里 model / extraction_model 为 ${WECHAT_TWIN_MODEL:…} 时生效。
# 若在应用「设置」里保存过模型，一般会写成纯文本，此时以 config.yaml 为准，不受此项覆盖。
WECHAT_TWIN_MODEL=gpt-4o

# API Base URL（可选，使用 OpenAI 官方则留空）
WECHAT_TWIN_BASE_URL=

# ── Rerank 配置（可选）──────────────────────────────────────────────────────

# Cohere API Key（使用 Cohere 重排时填写，local 模式可不填）
COHERE_API_KEY=

# ── 环境模式 ────────────────────────────────────────────────────────────────

# dev | prod（dev 模式下日志自动升级为 DEBUG）
XINYI_ENV=dev
